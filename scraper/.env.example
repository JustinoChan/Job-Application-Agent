API_BASE_URL=https://api.h4s.live
API_TOKEN=replace-with-the-API_TOKEN-from-the-backend-.env
WATCHLIST_PATH=watchlist.yaml
# UA defaults to "JobAgentScraper/0.4 (+https://github.com/JustinoChan/Job-Application-Agent)"
# Override if you fork — keeping a real contact URL is the polite default.
USER_AGENT=JobAgentScraper/0.4 (+https://github.com/JustinoChan/Job-Application-Agent)
REQUEST_TIMEOUT_SECONDS=20
DRY_RUN=false
# Politeness controls — applied globally across all source adapters.
# Sleep this long between *every* outbound HTTP call (in any source).
INTER_REQUEST_DELAY_SECONDS=1.0
# Retry 408/425/429/5xx with exponential backoff, honoring Retry-After.
MAX_RETRIES=3
# Freshness — drop postings with posted_at older than this many days.
# Set to 0 to disable. Defaults to 30.
MAX_POSTING_AGE_DAYS=30

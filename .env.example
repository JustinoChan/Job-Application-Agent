# FastAPI auth
# Local/dev: set AUTH_MODE=token and send Authorization: Bearer <API_TOKEN>.
# Deployed behind Cloudflare Access: set AUTH_MODE=cloudflare_access and protect the tunnel.
AUTH_MODE=token
API_TOKEN=replace-with-a-long-random-token
CLOUDFLARE_ACCESS_ALLOWED_EMAILS=you@example.com

# CORS origins for local or cross-origin deployment.
CORS_ORIGINS=http://localhost:5173

# Optional job extraction provider: none, openclaw, openai, anthropic.
LLM_PROVIDER=none
OPENAI_API_KEY=
OPENAI_JOB_EXTRACT_MODEL=gpt-5.5
ANTHROPIC_API_KEY=
ANTHROPIC_JOB_EXTRACT_MODEL=claude-3-5-sonnet-latest

# OpenClaw (local daemon with OAuth — no API keys needed).
# Set LLM_PROVIDER=openclaw to use.
OPENCLAW_COMMAND=openclaw
OPENCLAW_MODEL=openai-codex/gpt-5.4-mini
OPENCLAW_TIMEOUT_SECONDS=60

# Frontend.
# Prefer Cloudflare Access or a server-side proxy in production.
VITE_API_URL=http://localhost:8000
# Local dev only. Do not use as production security; Vite exposes it to the browser.
VITE_API_TOKEN=
